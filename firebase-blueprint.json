{
  "entities": {
    "Response": {
      "title": "User Response",
      "description": "User mobile usage behavior analysis data",
      "type": "object",
      "properties": {
        "ageGroup": { "type": "string", "enum": ["Below 18", "18–30", "31–50", "Above 50"] },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "occupation": { "type": "string", "enum": ["Student", "Employee", "Business", "Homemaker", "Farmer", "Retired", "Other"] },
        "dailyUsage": { "type": "string", "enum": ["Less than 1 hour", "1–3 hours", "3–6 hours", "More than 6 hours"] },
        "mainPurpose": { "type": "string" },
        "usagePurpose": { "type": "array", "items": { "type": "string" } },
        "socialMediaUsage": { "type": "string" },
        "checkAfterWaking": { "type": "string", "enum": ["Always", "Sometimes", "Never"] },
        "useBeforeSleep": { "type": "string", "enum": ["Always", "Sometimes", "Never"] },
        "feelsAddicted": { "type": "string", "enum": ["Yes", "No", "Maybe"] },
        "stayWithoutPhone": { "type": "string", "enum": ["Yes", "No", "Maybe"] },
        "usageWhileEating": { "type": "string", "enum": ["Often", "Sometimes", "Never"] },
        "status": { "type": "string", "enum": ["Healthy", "Moderate", "High Risk"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "digitalWellbeingScore": { "type": "integer" },
        "name": { "type": "string" }
      },
      "required": ["name", "ageGroup", "gender", "occupation", "dailyUsage", "mainPurpose", "usagePurpose", "socialMediaUsage", "checkAfterWaking", "useBeforeSleep", "feelsAddicted", "stayWithoutPhone", "usageWhileEating", "status", "createdAt"]
    }
  },
  "firestore": {
    "/responses/{responseId}": {
      "schema": "Response",
      "description": "Collection of user usage analysis responses"
    },
    "/userResponses/{userResponseId}": {
      "schema": "Response",
      "description": "Exhaustive collection of individual user response submissions for Google Sheets style analytics representation"
    }
  }
}
